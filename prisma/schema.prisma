generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["identity", "audit"]
}

model Organization {
  id           String   @id
  slug         String   @unique
  name         String
  displayName  String   @map("display_name")
  plan         String   @default("trial")
  isInternal   Boolean  @default(false) @map("is_internal")
  isActive     Boolean  @default(true) @map("is_active")
  appsEnabled  String[] @map("apps_enabled")
  address      Json?
  vatId        String?  @map("vat_id")
  billingEmail String?  @map("billing_email")
  logoUrl      String?  @map("logo_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  memberships  Membership[]
  sessions     Session[]

  @@map("organizations")
  @@schema("identity")
}

model User {
  id          String   @id
  email       String   @unique
  name        String
  imageUrl    String?  @map("image_url")
  isSuperadmin Boolean @default(false) @map("is_superadmin")
  isActive    Boolean  @default(true) @map("is_active")
  locale      String   @default("de-DE")
  timezone    String   @default("Europe/Berlin")
  lastSeenAt  DateTime? @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memberships   Membership[]
  sessions      Session[]
  magicTokens   MagicLinkToken[]

  @@map("users")
  @@schema("identity")
}

model Membership {
  id                   String   @id @default(cuid())
  userId               String   @map("user_id")
  orgId                String   @map("org_id")
  role                 String   @default("member")
  appsAccess           String[] @map("apps_access")
  rolePerApp           Json     @default("{}") @map("role_per_app")
  invitedBy            String?  @map("invited_by")
  acceptedAt           DateTime? @map("accepted_at")
  permissionsUpdatedAt DateTime @default(now()) @map("permissions_updated_at")
  createdAt            DateTime @default(now()) @map("created_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("memberships")
  @@schema("identity")
}

model MagicLinkToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  email     String
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("magic_link_tokens")
  @@schema("identity")
}

model Session {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  activeOrgId  String?  @map("active_org_id")
  sessionToken String   @unique @map("session_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization? @relation(fields: [activeOrgId], references: [id], onDelete: SetNull)

  @@map("sessions")
  @@schema("identity")
}
