# H+M Auth Service — Environment Variables
# Copy to .env.local for development

# Database (PostgreSQL on Hetzner)
DATABASE_URL=postgresql://postgres:PASSWORD@49.12.207.109:5678/postgres

# Auth
NEXTAUTH_URL=https://auth.hundm.cloud
AUTH_COOKIE_DOMAIN=.hundm.cloud

# Email (Brevo SMTP)
EMAIL_SERVER=smtp://user:pass@smtp-relay.brevo.com:587
EMAIL_FROM=noreply@hundm.cloud

# Allowed domains (comma-separated, leave empty to allow all)
ALLOWED_EMAIL_DOMAINS=die-bloechliger.de,dietrichs-gruppe.de,hundm.cloud
